# ===== AI 投资竞赛 · 环境变量清单 =====
# 复制本文件为 .env（仓库根目录），填入你自己的 key。
# .env 已在 .gitignore，绝不要 commit 到仓库。

# ---------- Twelve Data（美股收盘价）----------
# 注册：https://twelvedata.com  →  Dashboard → API Keys
# Free tier：800 credits/day，8 requests/min（30 symbols 需要分 4 批 + 62s 间隔）
TWELVE_DATA_KEY=your_twelve_data_api_key

# ---------- Supabase（数据二级备份，前端 + 后端共用）----------
# 注册：https://supabase.com  →  New Project
# 在 SQL Editor 里执行 migrations/001_ai_invest_snapshots.sql 建表
# URL + anon key 用于前端 fetch；service key 用于后端 upload_supabase.py
SUPABASE_URL=https://xxxxxxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ---------- 钉钉自定义机器人（可选）----------
# 不配置时 daily_run.py prompts 会打印警告跳过推送
# 注册：钉钉群设置 → 智能群助手 → 添加机器人 → 自定义 → 加签（关键词：情报采集）
DINGBOT_WEBHOOK=https://oapi.dingtalk.com/robot/send?access_token=xxxxxxxx

# ---------- 部署相关（CI 用，本地开发可不配）----------
# GitHub Actions 构建时注入，本地 npm run build 若部署到 Pages 子路径需要设为 true
GITHUB_PAGES=false
